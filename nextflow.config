// nextflow.config — local execution profile

// Enable Docker for containerised processes
docker {
    enabled    = true
    runOptions = "-u $(id -u):$(id -g) -v ${params.tmp_dir}:${params.tmp_dir}"  // run as current user to avoid root-owned outputs
}

profiles {

    local {
        process.executor = 'local'

        process {
            withName: 'GIRAFFE_ALIGN' {
                cpus   = 8
                memory = '32 GB'
            }
            withName: 'SAMTOOLS_SORT_INDEX' {
                cpus   = 4
                memory = '8 GB'
            }
            withName: 'DEEPVARIANT' {
                cpus   = 8
                memory = '32 GB'
            }
        }
    }
}

// Default (no profile) — conservative single-machine settings
process {
    cpus   = 4
    memory = '16 GB'
}

// Reporting
report {
    enabled = true
    file    = "reports/pipeline_report.html"
}

timeline {
    enabled = true
    file    = "reports/timeline.html"
}
